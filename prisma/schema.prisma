generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  parentId    String?
  parent      Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryChildren")
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([parentId])
  @@index([isActive, sortOrder])
}

model Product {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String
  fullDescription String?  @db.Text
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id])
  isActive        Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  badge           String?
  sortOrder       Int      @default(0)
  productType     String   @default("coffee") // "coffee" | "tea" | "instant"
  productForm     String? // tea: "листовой" | "пакетики" | instant: "гранулы" | "порошок" | "капсулы"

  // Coffee attributes (nullable for non-coffee products)
  origin           String?
  region           String?
  farm             String?
  altitude         String?
  roastLevel       String?
  processingMethod String?
  flavorNotes      String[] @default([])
  acidity          Int? // 0-100
  sweetness        Int? // 0-100
  bitterness       Int? // 0-100
  body             Int? // 0-100
  brewingMethods   String[] @default([])

  // Pack images
  smallImage String? // 250г pack image path, e.g. /images/coffee/Small/Peru.jpg

  // SEO
  metaTitle       String?
  metaDescription String?

  images      ProductImage[]
  variants    ProductVariant[]
  reviews     Review[]
  orderItems  OrderItem[]
  favorites   Favorite[]
  collections ProductCollectionItem[]
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([isActive, sortOrder])
  @@index([isActive, categoryId])
  @@index([isActive, productType])
  @@index([isActive, isFeatured, sortOrder])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  // P2-9: Restrict — удаление Product с привязанными Images блокируется на
  // уровне БД. В админке правильный путь — soft-delete через isActive=false.
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  url       String
  alt       String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)
}

model ProductVariant {
  id                String         @id @default(cuid())
  productId         String
  product           Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  weight            String // "250г", "500г", "1кг"
  price             Int // price in rubles
  oldPrice          Int?
  sku               String?
  stock             Int            @default(0)
  lowStockThreshold Int? // null = не отслеживать; при переходе stock ≤ threshold → уведомление в бот
  isActive          Boolean        @default(true)
  sortOrder         Int            @default(0)
  orderItems        OrderItem[]
  stockHistory      StockHistory[]
  linkedGifts       Gift[]         @relation("ProductVariantGifts")

  @@index([isActive, productId])
  @@index([stock])
}

model StockHistory {
  id          String         @id @default(cuid())
  variantId   String
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  delta       Int // +N приход / -N списание
  stockBefore Int
  stockAfter  Int
  reason      String // order_placed | order_cancelled | order_restored | supplier_received | inventory_correction | write_off
  orderId     String? // связанный заказ, если применимо
  notes       String?        @db.Text
  changedBy   String? // AdminUser.id | "customer" | "system"
  createdAt   DateTime       @default(now())

  @@index([variantId, createdAt])
  @@index([orderId])
  @@index([reason])
}

model Review {
  id        String   @id @default(cuid())
  productId String
  // P2-9: Restrict — исторические отзывы не должны пропадать при удалении
  // товара из каталога. Пользователи видят их в профиле и это источник
  // доверия. Удаляем через soft-delete (isActive=false на товаре).
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  name      String
  text      String   @db.Text
  rating    Int // 1-5
  isVisible Boolean  @default(true)
  date      String? // display date like "Ноябрь 2025"
  createdAt DateTime @default(now())

  @@index([productId, isVisible])
  @@index([isVisible])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("manager") // "admin" | "manager"
  status       String   @default("active") // "active" | "pending" | "blocked"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  activityLogs AdminActivityLog[]
}

model AdminActivityLog {
  id          String     @id @default(cuid())
  adminUserId String?
  admin       AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)
  adminName   String? // snapshot — чтобы лог выжил при удалении пользователя
  adminRole   String? // "admin" | "manager" в момент действия
  action      String // "order.status_changed", "stock.adjusted", "product.updated", "user.approved" и т.д.
  entityType  String? // "order" | "variant" | "product" | "review" | "admin_user" ...
  entityId    String?
  payload     Json? // произвольные детали: до/после, причина, старый/новый статус
  createdAt   DateTime   @default(now())

  @@index([adminUserId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model User {
  id                String             @id @default(cuid())
  email             String?            @unique
  emailVerified     DateTime?
  passwordHash      String?
  name              String?
  image             String?
  phone             String?
  avatarUrl         String?
  defaultAddress    String?            @db.Text
  telegramId        String?            @unique
  notifyOrderStatus Boolean            @default(true)
  notifyPromotions  Boolean            @default(false)
  notifyNewProducts Boolean            @default(false)
  bonusBalance      Int                @default(0)
  tasteProfile      Json? // aggregated taste profile, updated on each order
  accounts          Account[]
  orders            Order[]
  sessions          Session[]
  favorites         Favorite[]
  addresses         Address[]
  bonusTransactions BonusTransaction[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      String // "email_verify" | "password_reset"
  expiresAt DateTime
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, type])
}

model PromoCode {
  id             String   @id @default(cuid())
  name           String
  comment        String?  @db.Text
  code           String   @unique
  type           String // "percent" | "fixed"
  value          Int // 10 = 10% or 500 = 500₽
  startDate      DateTime
  endDate        DateTime
  usageCount     Int      @default(0)
  maxUsage       Int?
  maxPerCustomer Int?
  minOrderSum    Int?
  isActive       Boolean  @default(true)
  orders         Order[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  status          String      @default("pending") // pending/confirmed/shipped/delivered/cancelled
  customerName    String
  customerEmail   String?
  customerPhone   String
  deliveryAddress String?     @db.Text
  deliveryMethod  String?
  paymentMethod   String?
  subtotal        Int
  deliveryPrice   Int         @default(0)
  discount        Int         @default(0)
  total           Int
  bonusUsed       Int         @default(0)
  bonusEarned     Int         @default(0)
  paymentId       String? // UUID платежа ЮKassa
  paymentStatus   String? // "pending" | "succeeded" | "canceled"
  notes           String?     @db.Text
  thankYouToken   String?     @unique
  trackingToken   String?     @unique
  userId          String?
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  promoCodeId     String?
  promoCode       PromoCode?  @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  items           OrderItem[]

  // Delivery module fields
  carrierOrderId      String? // UUID заказа у перевозчика
  carrierOrderNum     String? // человекочитаемый номер
  trackingNumber      String?
  pickupPointCode     String? // код ПВЗ
  pickupPointName     String? // название (снапшот)
  deliveryType        String? // "door" | "pvz"
  destinationCity     String?
  destinationCityCode String?
  carrierStatus       String? // последний статус от перевозчика
  estimatedDelivery   String? // "3-5 дней"
  packageWeight       Int? // суммарный брутто-вес всех коробок, граммы
  packagePlan         Json? // физический план упаковки: массив коробок (length/width/height/weight/presetCode)
  tariffCode          Int? // код тарифа перевозчика
  postalCode          String? // почтовый индекс получателя
  adminNotes          String? @db.Text

  // Gift-интеграция: выбранный клиентом подарок (nullable; заполняется только
  // если cartTotal >= Gift.minCartTotal на момент оформления).
  // onDelete: SetNull — удаление подарка из каталога не роняет исторические заказы.
  selectedGiftId String?
  selectedGift   Gift?   @relation(fields: [selectedGiftId], references: [id], onDelete: SetNull)
  // Снапшот имени — чтобы даже при удалении Gift клиент/админ видели что клали.
  giftNameSnapshot String?

  statusLogs OrderStatusLog[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([paymentId])
  @@index([status])
  @@index([deliveryMethod, status])
  @@index([userId])
  @@index([createdAt])
  @@index([customerPhone])
  @@index([customerEmail])
  @@index([status, createdAt])
  @@index([selectedGiftId])
}

// Подарок, который кладётся в заказ бесплатно когда сумма заказа достигла
// порога minCartTotal. Пул подарков управляется через /admin/gifts.
// Клиент на checkout видит все активные подарки со своим cartTotal >= minCartTotal
// и выбирает один (radio).
model Gift {
  id           String   @id @default(cuid())
  // Название для клиента. Для linked-gift можно оставить свой маркетинговый
  // текст («Образец Эфиопия в подарок») — он покажется клиенту вместо
  // product.name, но на складе/адмике показан линк на реальный ProductVariant.
  name         String
  description  String?  @db.Text
  imageUrl     String?  // /uploads/gifts/{id}/xxx.webp — custom или копия product image
  imageAlt     String?
  // Порог cartTotal (после скидки, до бонусов) — от какой суммы подарок доступен.
  minCartTotal Int      @default(0)
  // Stock-логика:
  //   - productVariantId задан → stock НЕ используется; читаем ProductVariant.stock,
  //     декрементим его через adjustStock(reason="gifted"). Это кейс «дарим неликвид».
  //   - productVariantId NULL + stock NULL → unlimited custom gift (открытка, наклейка).
  //   - productVariantId NULL + stock=число → custom gift с ограниченным запасом.
  stock        Int?
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)

  // Линк на вариант товара из каталога — использовать для дарения неликвида.
  // onDelete: SetNull — удаление товара не роняет Gift-запись; админ увидит
  // в UI что линка нет и переконфигурирует.
  productVariantId String?
  productVariant   ProductVariant? @relation("ProductVariantGifts", fields: [productVariantId], references: [id], onDelete: SetNull)

  orders       Order[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive, minCartTotal])
  @@index([productVariantId])
}

model OrderStatusLog {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus String
  toStatus   String
  changedBy  String?
  createdAt  DateTime @default(now())

  @@index([orderId])
}

model OrderItem {
  id        String          @id @default(cuid())
  orderId   String
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  name      String // snapshot
  weight    String // snapshot
  price     Int // snapshot
  quantity  Int

  @@index([orderId])
}

model ArticleCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  articles    Article[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Article {
  id              String           @id @default(cuid())
  title           String
  slug            String           @unique
  excerpt         String           @db.Text
  content         String           @db.Text
  coverImage      String?
  categoryId      String?
  category        ArticleCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags            String[]         @default([])
  isPublished     Boolean          @default(false)
  publishedAt     DateTime?
  viewCount       Int              @default(0)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([isPublished, publishedAt])
  @@index([categoryId, isPublished])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

model Address {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  fullAddress    String   @db.Text
  recipientName  String?
  recipientPhone String?
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model BonusTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Int
  type        String // "earned" | "spent" | "admin_adjustment"
  description String
  orderId     String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([orderId])
}

model ProductCollection {
  id          String                  @id @default(cuid())
  name        String
  slug        String                  @unique
  description String?
  emoji       String?
  sortOrder   Int                     @default(0)
  isActive    Boolean                 @default(true)
  products    ProductCollectionItem[]
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
}

model ProductCollectionItem {
  id           String            @id @default(cuid())
  collectionId String
  collection   ProductCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  productId    String
  product      Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder    Int               @default(0)

  @@unique([collectionId, productId])
  @@index([collectionId])
  @@index([productId])
}

model DeliverySetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model DeliveryMarkupRule {
  id        String   @id @default(cuid())
  name      String
  carrier   String // "cdek" | "pochta" | "all"
  type      String // "percent" | "fixed" | "replace"
  value     Int // 15 = +15%, 200 = +200₽
  minWeight Int?
  maxWeight Int?
  minPrice  Int? // мин. сумма корзины
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeliveryRule {
  id               String   @id @default(cuid())
  name             String
  carrier          String // "pochta" | "cdek" | "courier" | "all"
  deliveryType     String? // "pvz" | "door" | null = any
  minCartTotal     Int? // cart total >= X
  maxDeliveryPrice Int? // calculated delivery price < Y
  city             String? // specific city name (exact match)
  action           String // "free" | "discount" | "disable"
  discountAmount   Int? // for "discount" action: reduce by N₽
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Outbox pattern: events queued for delivery to external systems (millorbot, etc.)
model OutboxEvent {
  id             String    @id @default(cuid())
  eventId        String    @unique // UUID — used for idempotency on receiver side
  topic          String // "order.paid" | "order.status.changed" | ...
  payload        Json // full event body
  status         String    @default("pending") // "pending" | "delivered" | "failed" | "dead"
  attempts       Int       @default(0)
  nextAttemptAt  DateTime  @default(now())
  lastError      String?   @db.Text
  lastStatusCode Int?
  deliveredAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, nextAttemptAt])
  @@index([topic])
  @@index([createdAt])
}

// Idempotency registry for inbound webhooks (prevents double-processing).
// An entry is inserted only AFTER successful processing, so failed attempts can be retried.
model ProcessedInboundEvent {
  id        String   @id @default(cuid())
  source    String // "millorbot" | ...
  eventId   String
  createdAt DateTime @default(now())

  @@unique([source, eventId])
  @@index([createdAt])
}

// Email dispatch — audit + idempotency + durable queue.
// Жизненный цикл status: "pending" → "sent" | "failed" → (retry) → "sent" | "dead".
// Snapshot (subject/html) сохраняется ДО вызова SMTP — при рестарте контейнера
// письмо не теряется, воркер продолжит отправку. Retry с экспоненциальным backoff
// по nextAttemptAt. Idempotency по (orderId, kind, recipient, status="sent").
model EmailDispatch {
  id            String    @id @default(cuid())
  orderId       String? // null для non-order писем (verify/reset)
  kind          String // "order.confirmation" | "admin.new_order" | "order.payment_success" | ...
  recipient     String // email получателя
  status        String // "pending" | "sent" | "failed" | "dead"
  attempts      Int       @default(0) // число выполненных попыток SMTP
  nextAttemptAt DateTime  @default(now()) // worker забирает где status in (pending,failed) AND nextAttemptAt <= now
  subject       String? // snapshot темы для ретрая
  html          String?   @db.Text // snapshot HTML-тела для ретрая
  fromEmail     String? // from-override, null = SMTP_USER
  messageId     String? // SMTP message-id из ответа nodemailer
  response      String?   @db.Text // raw SMTP response ("250 OK id=...")
  error         String?   @db.Text // последняя ошибка отправки
  sentAt        DateTime? // timestamp успешной доставки
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([orderId, kind, recipient, status])
  @@index([orderId, createdAt])
  @@index([status, nextAttemptAt])
  @@index([status, createdAt])
  @@index([kind, createdAt])
}

// Log of all integration events (inbound + outbound) for diagnostics
model IntegrationLog {
  id         String   @id @default(cuid())
  direction  String // "inbound" | "outbound"
  source     String // "millorbot" | "cdek" | "pochta" | "yookassa"
  event      String // "order.paid" | "tracking.updated" | ...
  eventId    String? // optional — matches OutboxEvent.eventId or inbound event_id
  statusCode Int?
  request    Json?
  response   Json?
  error      String?  @db.Text
  durationMs Int?
  createdAt  DateTime @default(now())

  @@index([source, event, createdAt])
  @@index([eventId])
  @@index([createdAt])
}
