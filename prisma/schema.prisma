generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  parentId    String?
  parent      Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryChildren")
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([parentId])
  @@index([isActive, sortOrder])
}

model Product {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String
  fullDescription String?  @db.Text
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id])
  isActive        Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  badge           String?
  sortOrder       Int      @default(0)
  productType     String   @default("coffee") // "coffee" | "tea" | "instant"
  productForm     String? // tea: "листовой" | "пакетики" | instant: "гранулы" | "порошок" | "капсулы"

  // Coffee attributes (nullable for non-coffee products)
  origin           String?
  region           String?
  farm             String?
  altitude         String?
  roastLevel       String?
  processingMethod String?
  flavorNotes      String[] @default([])
  acidity          Int? // 0-100
  sweetness        Int? // 0-100
  bitterness       Int? // 0-100
  body             Int? // 0-100
  brewingMethods   String[] @default([])

  // G5: Premium coffee attributes — ключевые для позиционирования specialty-кофе.
  // Coffee enthusiasts платят 2-3× больше за прозрачность происхождения.
  // Все nullable, заполняются в админке по мере наличия данных.
  elevationMin  Int? // метры над уровнем моря (нижняя граница диапазона, если farm на холме)
  elevationMax  Int?
  harvestDate   DateTime? // дата урожая (обычно округляем до месяца)
  roastedAt     DateTime? // дата обжарки — КРИТИЧНАЯ для "свежеобжаренного". Отображается как "2 дня назад".
  batchId       String? // партия обжарки — трейсабилити ("та же кружка Peru из партии B-048")
  tasterNotes   String? // ноты от куппера (professional), отдельно от flavorNotes для casual
  cupper        String? // имя куппера (для доверия и PR)
  sca           Int? // SCA score 80-100 (specialty если >= 80). null для commercial.

  // Pack images
  smallImage String? // 250г pack image path, e.g. /images/coffee/Small/Peru.jpg

  // SEO
  metaTitle       String?
  metaDescription String?

  // Денормализованный rating — обновляется через recomputeProductRating()
  // при создании/обновлении/удалении Review. Избавляет каталог от N+1:
  // вместо подгрузки всех reviews.rating → один Integer/Decimal.
  avgRating   Float? // null = нет отзывов
  reviewCount Int    @default(0)

  images      ProductImage[]
  variants    ProductVariant[]
  reviews     Review[]
  orderItems  OrderItem[]
  favorites   Favorite[]
  collections ProductCollectionItem[]
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([isActive, sortOrder])
  @@index([isActive, categoryId])
  @@index([isActive, productType])
  @@index([isActive, isFeatured, sortOrder])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  // P2-9: Restrict — удаление Product с привязанными Images блокируется на
  // уровне БД. В админке правильный путь — soft-delete через isActive=false.
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  url       String
  alt       String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)
}

model ProductVariant {
  id                   String          @id @default(cuid())
  productId            String
  product              Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  weight               String // "250г", "500г", "1кг"
  price                Int // price in rubles
  oldPrice             Int?
  sku                  String?
  stock                Int             @default(0)
  lowStockThreshold    Int? // null = не отслеживать; при переходе stock ≤ threshold → уведомление в бот
  isActive             Boolean         @default(true)
  sortOrder            Int             @default(0)
  // B2B: минимальный оптовый заказ по SKU (null = без ограничения)
  wholesaleMinQuantity Int?
  orderItems           OrderItem[]
  stockHistory         StockHistory[]
  linkedGifts          Gift[]          @relation("ProductVariantGifts")
  priceListItems       PriceListItem[]

  @@index([isActive, productId])
  @@index([stock])
}

model StockHistory {
  id          String          @id @default(cuid())
  // variantId nullable + SetNull — история должна пережить удаление варианта.
  // Если админ удалил variant, записи остаются для аудита «куда ушёл stock».
  // Pages которые ищут историю по конкретному variant фильтруют `variantId: id`,
  // записи с null остаются только для cross-period аналитики.
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  delta       Int // +N приход / -N списание
  stockBefore Int
  stockAfter  Int
  reason      String // order_placed | order_cancelled | order_restored | supplier_received | inventory_correction | write_off
  orderId     String? // связанный заказ, если применимо
  notes       String?         @db.Text
  changedBy   String? // AdminUser.id | "customer" | "system"
  createdAt   DateTime        @default(now())

  @@index([variantId, createdAt])
  @@index([orderId])
  @@index([reason])
}

model Review {
  id        String   @id @default(cuid())
  productId String
  // P2-9: Restrict — исторические отзывы не должны пропадать при удалении
  // товара из каталога. Пользователи видят их в профиле и это источник
  // доверия. Удаляем через soft-delete (isActive=false на товаре).
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  name      String
  text      String   @db.Text
  rating    Int // 1-5
  isVisible Boolean  @default(true)
  date      String? // display date like "Ноябрь 2025"
  createdAt DateTime @default(now())

  @@index([productId, isVisible])
  @@index([isVisible])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("manager") // "admin" | "manager"
  status       String   @default("active") // "active" | "pending" | "blocked"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  activityLogs AdminActivityLog[]
}

model AdminActivityLog {
  id          String     @id @default(cuid())
  adminUserId String?
  admin       AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)
  adminName   String? // snapshot — чтобы лог выжил при удалении пользователя
  adminRole   String? // "admin" | "manager" в момент действия
  action      String // "order.status_changed", "stock.adjusted", "product.updated", "user.approved" и т.д.
  entityType  String? // "order" | "variant" | "product" | "review" | "admin_user" ...
  entityId    String?
  payload     Json? // произвольные детали: до/после, причина, старый/новый статус
  createdAt   DateTime   @default(now())

  @@index([adminUserId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
  // Compliance audit: «все действия типа X над объектами типа Y за период».
  @@index([action, entityType, createdAt])
}

/// G3: Abandoned cart recovery. Snapshot корзины ЛЕВЫЙ в момент введения
/// email на checkout step 1. Если юзер не оформил заказ в течение часа —
/// cron отправляет письмо с персональным промо-кодом и deep-link'ом на
/// восстановление корзины.
///
/// Не храним full-items в реальном User — это Zustand локальной. Только
/// snapshot JSON для email-генерации + recoveryToken для deep-link.
///
/// Жизненный цикл:
///   - tracked: snapshot создан, cron ещё не отправлял
///   - email_sent: cron отправил; если Order создался, помечаем recovered
///   - recovered: юзер реально оформил заказ после клика по deep-link
///   - expired: прошло 72 часа без recovered
model AbandonedCart {
  id             String    @id @default(cuid())
  email          String
  userId         String?   // если авторизован — полезно для сегментации
  items          Json      // snapshot [{ variantId, name, weight, price, qty, slug, image }]
  subtotal       Int       // для template'а и promo-условий (min-threshold)
  recoveryToken  String    @unique
  promoCodeId    String?   // one-time промо-код для recovery (опционально)
  status         String    @default("tracked") // tracked|email_sent|recovered|expired
  emailSentAt    DateTime?
  recoveredAt    DateTime?
  recoveredOrderId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([email, status])
  @@index([status, createdAt])
  @@index([userId])
}

/// G1-2: подписчики email-рассылок. Отдельно от User — подписка по
/// email не требует регистрации. Статусы: active (получает письма),
/// unsubscribed (отписался), bounced (soft/hard bounce от SMTP).
/// Группы (subscriptionGroups) позволяют сегментировать рассылку:
/// ["promotions"] — только скидки, ["new_products"] — новинки, etc.
model NewsletterSubscriber {
  id                 String    @id @default(cuid())
  email              String    @unique
  status             String    @default("active") // "active" | "unsubscribed" | "bounced"
  // Группы подписок — array TEXT. Хэштег-стиль фильтрация в cron'е.
  subscriptionGroups String[]  @default(["promotions"])
  // Привязка к юзеру (если есть) — необязательно, но полезно для CRM.
  userId             String?
  user               User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  source             String?   // "footer_form" | "checkout" | "register"
  // unsubscribeToken — одноразовый для one-click отписки из письма,
  // без логина. Ротируется при subscribe заново.
  unsubscribeToken   String    @unique
  ipAddress          String?
  userAgent          String?   @db.Text
  createdAt          DateTime  @default(now())
  unsubscribedAt     DateTime?
  bouncedAt          DateTime?

  @@index([status, createdAt])
  @@index([userId])
}

/// Хранение согласия на обработку ПД (152-ФЗ требует письменного
/// согласия + документирование для предъявления Роскомнадзору).
/// Создаётся при submit checkout / регистрации с IP + User-Agent +
/// version текста оферты на момент клика. Не удаляется — только revokedAt.
model UserConsent {
  id            String    @id @default(cuid())
  // userId nullable — гостевой заказ тоже даёт согласие (по email).
  userId        String?
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Email+name снимок — если юзер удалён, согласие остаётся anonymized.
  emailSnapshot String?
  // Тип согласия: privacy (обязательное), marketing (subscribe),
  // cookies (для будущего cookie-banner).
  type          String // "privacy" | "marketing" | "cookies"
  version       Int       @default(1) // версия текста на момент согласия
  acceptedAt    DateTime  @default(now())
  revokedAt     DateTime?
  ipAddress     String?
  userAgent     String?   @db.Text
  // Контекст: при каком действии было дано согласие.
  source        String // "checkout" | "register" | "settings" | "cookie_banner"
  orderId       String? // если источник — checkout

  @@index([userId, type])
  @@index([type, acceptedAt])
}

/// User DELETE policy (см. F1-3 в master-roadmap-2026-04-23.md):
/// НИКОГДА не вызываем `prisma.user.delete()` в коде или вручную. Вместо
/// этого — soft-delete через `deletedAt + анонимизация email/name/phone`.
/// Это защищает связи (Order, BonusTransaction, AdminActivityLog) от
/// каскадного удаления. Любой новый Cascade FK на User приведёт к data-loss.
model User {
  id                String             @id @default(cuid())
  email             String?            @unique
  emailVerified     DateTime?
  passwordHash      String?
  name              String?
  image             String?
  phone             String?
  avatarUrl         String?
  defaultAddress    String?            @db.Text
  telegramId        String?            @unique
  notifyOrderStatus Boolean            @default(true)
  notifyPromotions  Boolean            @default(false)
  notifyNewProducts Boolean            @default(false)
  bonusBalance      Int                @default(0)
  tasteProfile      Json? // aggregated taste profile, updated on each order
  accounts          Account[]
  orders            Order[]
  sessions          Session[]
  favorites         Favorite[]
  addresses         Address[]
  bonusTransactions BonusTransaction[]
  consents          UserConsent[]
  newsletterSubscriptions NewsletterSubscriber[]
  // Welcome-discount: время первой оплаченной покупки. Пока null — юзер
  // имеет право на welcome-скидку (% настраивается через DeliverySetting).
  // Проставляется в createOrder при отсутствии. Даже если заказ потом
  // отменят — welcome не восстанавливается (иначе абуз: оформил → отменил
  // → опять скидка). Для честности — админ может вручную сбросить через SQL.
  firstOrderCompletedAt DateTime?
  // Soft-delete: при удалении аккаунта через /account/delete проставляем
  // deletedAt и анонимизируем email/name/phone. БД-связи (Order, BonusTransaction)
  // сохраняются для бухучёта и compliance. Физическое удаление — никогда.
  deletedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([deletedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

// (VerificationCode: ниже добавлен @@index([email, expiresAt]) для cron cleanup)
model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      String // "email_verify" | "password_reset"
  expiresAt DateTime
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, type])
  // Cron cleanup: ищет expired + unused коды для удаления.
  @@index([email, expiresAt])
}

model PromoCode {
  id             String   @id @default(cuid())
  name           String
  comment        String?  @db.Text
  code           String   @unique
  type           String // "percent" | "fixed"
  value          Int // 10 = 10% or 500 = 500₽
  startDate      DateTime
  endDate        DateTime
  usageCount     Int      @default(0)
  maxUsage       Int?
  maxPerCustomer Int?
  minOrderSum    Int?
  isActive       Boolean  @default(true)
  // B2B: на какой канал действует промокод
  channel        String   @default("retail") // "retail" | "wholesale" | "both"
  orders         Order[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  status          String      @default("pending") // pending/confirmed/shipped/delivered/cancelled
  customerName    String
  customerEmail   String?
  customerPhone   String
  deliveryAddress String?     @db.Text
  deliveryMethod  String?
  paymentMethod   String?
  subtotal        Int
  deliveryPrice   Int         @default(0)
  discount        Int         @default(0)
  total           Int
  bonusUsed       Int         @default(0)
  bonusEarned     Int         @default(0)
  paymentId       String? // UUID платежа ЮKassa
  paymentStatus   String? // "pending" | "succeeded" | "canceled"
  notes           String?     @db.Text
  thankYouToken   String?     @unique
  trackingToken   String?     @unique
  userId          String?
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  promoCodeId     String?
  promoCode       PromoCode?  @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  items           OrderItem[]

  // Delivery module fields
  carrierOrderId      String? // UUID заказа у перевозчика
  carrierOrderNum     String? // человекочитаемый номер
  trackingNumber      String?
  pickupPointCode     String? // код ПВЗ
  pickupPointName     String? // название (снапшот)
  deliveryType        String? // "door" | "pvz"
  destinationCity     String?
  destinationCityCode String?
  carrierStatus       String? // последний статус от перевозчика
  estimatedDelivery   String? // "3-5 дней"
  packageWeight       Int? // суммарный брутто-вес всех коробок, граммы
  packagePlan         Json? // физический план упаковки: массив коробок (length/width/height/weight/presetCode)
  tariffCode          Int? // код тарифа перевозчика
  postalCode          String? // почтовый индекс получателя
  adminNotes          String? @db.Text

  // Gift-интеграция: выбранный клиентом подарок (nullable; заполняется только
  // если cartTotal >= Gift.minCartTotal на момент оформления).
  // onDelete: SetNull — удаление подарка из каталога не роняет исторические заказы.
  selectedGiftId   String?
  selectedGift     Gift?   @relation(fields: [selectedGiftId], references: [id], onDelete: SetNull)
  // Снапшот имени — чтобы даже при удалении Gift клиент/админ видели что клали.
  giftNameSnapshot String?

  // B2B-канал: обычный розничный заказ или оптовый.
  // Отдельной таблицы не заводим — общий склад, общий админ-UI, общий webhook-flow.
  // Специфика опта хранится в опциональных полях ниже + снапшоте реквизитов компании.
  channel            String            @default("retail") // "retail" | "wholesale"
  wholesaleCompanyId String?
  wholesaleCompany   WholesaleCompany? @relation(fields: [wholesaleCompanyId], references: [id], onDelete: SetNull)
  wholesaleUserId    String? // WholesaleUser.id — кто из компании оформил (без FK, чтобы не ломать историю при удалении юзера)
  paymentTerms       String? // "prepay" | "net7" | "net14" | "net30" | "net60" — снапшот условий на момент заказа
  approvalStatus     String? // "pending_approval" | "approved" | "rejected" — для net-terms заказов, null для prepay
  approvedById       String? // AdminUser.id
  approvedAt         DateTime?
  // Юридические реквизиты снапшот — компания может изменить реквизиты, заказ останется с оригинальными
  b2bLegalName       String?
  b2bInn             String?
  b2bKpp             String?

  statusLogs OrderStatusLog[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([paymentId])
  @@index([status])
  @@index([deliveryMethod, status])
  @@index([userId])
  @@index([createdAt])
  @@index([customerPhone])
  @@index([customerEmail])
  @@index([status, createdAt])
  @@index([selectedGiftId])
  // Профиль клиента: заказы юзера в конкретном статусе за период.
  @@index([userId, status, createdAt])
  // B2B: разделение каналов в админских списках и отчётах.
  @@index([channel, status, createdAt])
  @@index([wholesaleCompanyId, createdAt])
  @@index([approvalStatus])
}

// Подарок, который кладётся в заказ бесплатно когда сумма заказа достигла
// порога minCartTotal. Пул подарков управляется через /admin/gifts.
// Клиент на checkout видит все активные подарки со своим cartTotal >= minCartTotal
// и выбирает один (radio).
model Gift {
  id           String  @id @default(cuid())
  // Название для клиента. Для linked-gift можно оставить свой маркетинговый
  // текст («Образец Эфиопия в подарок») — он покажется клиенту вместо
  // product.name, но на складе/адмике показан линк на реальный ProductVariant.
  name         String
  description  String? @db.Text
  imageUrl     String? // /uploads/gifts/{id}/xxx.webp — custom или копия product image
  imageAlt     String?
  // Порог cartTotal (после скидки, до бонусов) — от какой суммы подарок доступен.
  minCartTotal Int     @default(0)
  // Stock-логика:
  //   - productVariantId задан → stock НЕ используется; читаем ProductVariant.stock,
  //     декрементим его через adjustStock(reason="gifted"). Это кейс «дарим неликвид».
  //   - productVariantId NULL + stock NULL → unlimited custom gift (открытка, наклейка).
  //   - productVariantId NULL + stock=число → custom gift с ограниченным запасом.
  stock        Int?
  isActive     Boolean @default(true)
  sortOrder    Int     @default(0)

  // Линк на вариант товара из каталога — использовать для дарения неликвида.
  // onDelete: SetNull — удаление товара не роняет Gift-запись; админ увидит
  // в UI что линка нет и переконфигурирует.
  productVariantId String?
  productVariant   ProductVariant? @relation("ProductVariantGifts", fields: [productVariantId], references: [id], onDelete: SetNull)

  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, minCartTotal])
  @@index([productVariantId])
}

model OrderStatusLog {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus String
  toStatus   String
  changedBy  String?
  createdAt  DateTime @default(now())

  @@index([orderId])
}

model OrderItem {
  id        String          @id @default(cuid())
  orderId   String
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  name      String // snapshot
  weight    String // snapshot
  price     Int // snapshot
  quantity  Int

  @@index([orderId])
}

model ArticleCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  articles    Article[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Article {
  id              String           @id @default(cuid())
  title           String
  slug            String           @unique
  excerpt         String           @db.Text
  content         String           @db.Text
  coverImage      String?
  categoryId      String?
  category        ArticleCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags            String[]         @default([])
  isPublished     Boolean          @default(false)
  publishedAt     DateTime?
  viewCount       Int              @default(0)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([isPublished, publishedAt])
  @@index([categoryId, isPublished])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

model Address {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  fullAddress    String   @db.Text
  recipientName  String?
  recipientPhone String?
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model BonusTransaction {
  id             String   @id @default(cuid())
  // userId nullable + onDelete SetNull — при удалении/анонимизации юзера
  // сохраняем финансовую историю. Физическое удаление транзакций делает
  // невозможным аудит баланса и compliance-проверки. 152-ФЗ допускает
  // хранение обезличенных данных для бухгалтерского учёта.
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  amount         Int
  type           String // "earned" | "spent" | "admin_adjustment"
  description    String
  orderId        String?
  // Idempotency для денежных операций — одна и та же транзакция не должна
  // дублироваться при retry webhook/cron. Используется в webhook ЮKassa,
  // cron-начислениях и refund-flow.
  idempotencyKey String?  @unique
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([orderId])
  @@index([userId, type, createdAt])
}

model ProductCollection {
  id          String                  @id @default(cuid())
  name        String
  slug        String                  @unique
  description String?
  emoji       String?
  sortOrder   Int                     @default(0)
  isActive    Boolean                 @default(true)
  products    ProductCollectionItem[]
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
}

model ProductCollectionItem {
  id           String            @id @default(cuid())
  collectionId String
  collection   ProductCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  productId    String
  product      Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder    Int               @default(0)

  @@unique([collectionId, productId])
  @@index([collectionId])
  @@index([productId])
}

model DeliverySetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model DeliveryMarkupRule {
  id        String   @id @default(cuid())
  name      String
  carrier   String // "cdek" | "pochta" | "all"
  type      String // "percent" | "fixed" | "replace"
  value     Int // 15 = +15%, 200 = +200₽
  minWeight Int?
  maxWeight Int?
  minPrice  Int? // мин. сумма корзины
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeliveryRule {
  id               String   @id @default(cuid())
  name             String
  carrier          String // "pochta" | "cdek" | "courier" | "all"
  deliveryType     String? // "pvz" | "door" | null = any
  minCartTotal     Int? // cart total >= X
  maxDeliveryPrice Int? // calculated delivery price < Y
  city             String? // specific city name (exact match)
  action           String // "free" | "discount" | "disable"
  discountAmount   Int? // for "discount" action: reduce by N₽
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Outbox pattern: events queued for delivery to external systems (millorbot, etc.)
model OutboxEvent {
  id             String    @id @default(cuid())
  eventId        String    @unique // UUID — used for idempotency on receiver side
  topic          String // "order.paid" | "order.status.changed" | ...
  payload        Json // full event body
  status         String    @default("pending") // "pending" | "delivered" | "failed" | "dead"
  attempts       Int       @default(0)
  nextAttemptAt  DateTime  @default(now())
  lastError      String?   @db.Text
  lastStatusCode Int?
  deliveredAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, nextAttemptAt])
  @@index([topic])
  @@index([createdAt])
}

// Idempotency registry for inbound webhooks (prevents double-processing).
// An entry is inserted only AFTER successful processing, so failed attempts can be retried.
model ProcessedInboundEvent {
  id        String   @id @default(cuid())
  source    String // "millorbot" | ...
  eventId   String
  createdAt DateTime @default(now())

  @@unique([source, eventId])
  @@index([createdAt])
  // TTL cleanup: ищем старые события одного source для удаления.
  @@index([source, createdAt])
}

// Email dispatch — audit + idempotency + durable queue.
// Жизненный цикл status: "pending" → "sent" | "failed" → (retry) → "sent" | "dead".
// Snapshot (subject/html) сохраняется ДО вызова SMTP — при рестарте контейнера
// письмо не теряется, воркер продолжит отправку. Retry с экспоненциальным backoff
// по nextAttemptAt. Idempotency по (orderId, kind, recipient, status="sent").
model EmailDispatch {
  id            String    @id @default(cuid())
  orderId       String? // null для non-order писем (verify/reset)
  kind          String // "order.confirmation" | "admin.new_order" | "order.payment_success" | ...
  recipient     String // email получателя
  status        String // "pending" | "sent" | "failed" | "dead"
  attempts      Int       @default(0) // число выполненных попыток SMTP
  nextAttemptAt DateTime  @default(now()) // worker забирает где status in (pending,failed) AND nextAttemptAt <= now
  subject       String? // snapshot темы для ретрая
  html          String?   @db.Text // snapshot HTML-тела для ретрая
  fromEmail     String? // from-override, null = SMTP_USER
  messageId     String? // SMTP message-id из ответа nodemailer
  response      String?   @db.Text // raw SMTP response ("250 OK id=...")
  error         String?   @db.Text // последняя ошибка отправки
  sentAt        DateTime? // timestamp успешной доставки
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([orderId, kind, recipient, status])
  @@index([orderId, createdAt])
  @@index([status, nextAttemptAt])
  @@index([status, createdAt])
  @@index([kind, createdAt])
  // Replay очередь: «какие письма типа X в статусе Y за период».
  @@index([kind, status, createdAt])
}

// Log of all integration events (inbound + outbound) for diagnostics
model IntegrationLog {
  id         String   @id @default(cuid())
  direction  String // "inbound" | "outbound"
  source     String // "millorbot" | "cdek" | "pochta" | "yookassa"
  event      String // "order.paid" | "tracking.updated" | ...
  eventId    String? // optional — matches OutboxEvent.eventId or inbound event_id
  statusCode Int?
  request    Json?
  response   Json?
  error      String?  @db.Text
  durationMs Int?
  createdAt  DateTime @default(now())

  @@index([source, event, createdAt])
  @@index([eventId])
  @@index([createdAt])
}

// ========================================================================
// Wholesale (B2B) — Кабинет оптовика
// ========================================================================

// Юридическое лицо — контрагент оптовой торговли. Может иметь несколько
// пользователей (закупщики, бухгалтер), один активный прайс-лист, один
// кредитный лимит. Статус "pending" — только что одобренная заявка,
// ожидает завершения настройки админом; "active" — работает; "suspended" —
// временно приостановлена (долг, нарушение); "rejected" — не активна.
model WholesaleCompany {
  id                 String                       @id @default(cuid())
  legalName          String // ООО "Ромашка"
  brandName          String? // публичное название (может совпадать)
  inn                String                       @unique // основной идентификатор
  kpp                String?
  ogrn               String?
  legalAddress       String?                      @db.Text
  postalAddress      String?                      @db.Text
  // Банковские реквизиты (для генерации счетов, Фаза 5)
  bankName           String?
  bankBic            String?
  bankAccount        String?
  corrAccount        String?
  // Контактные данные
  contactName        String?
  contactPhone       String?
  contactEmail       String?
  // Статус аккаунта
  status             String                       @default("active") // "active" | "suspended" | "rejected"
  // Бизнес-условия
  paymentTerms       String                       @default("prepay") // "prepay" | "net7" | "net14" | "net30" | "net60"
  creditLimit        Int                          @default(0) // в рублях
  creditUsed         Int                          @default(0) // неоплаченные заказы
  // Ценообразование
  priceListId        String?
  priceList          PriceList?                   @relation(fields: [priceListId], references: [id], onDelete: SetNull)
  // Кто одобрил заявку
  approvedById       String? // AdminUser.id
  approvedAt         DateTime?
  // Ответственный менеджер (CRM)
  managerAdminId     String? // AdminUser.id
  notes              String?                      @db.Text // внутренние заметки
  // Фаза 6: cron-алерты на превышение кредитного лимита.
  // creditAlertSentAt — последний раз, когда было уведомление;
  // cron не отправляет повторно пока creditUsed не упадёт и снова не вырастет.
  creditAlertSentAt  DateTime?
  creditAlertPctSent Int? // 80 | 90 | 100 — последний порог, о котором уведомили
  // Фаза 8: snapshot DaData для audit-проверки юрлица.
  dadataStatus       String? // "ACTIVE" | "LIQUIDATING" | "LIQUIDATED" | "REORGANIZING" | "BANKRUPT"
  dadataCheckedAt    DateTime?
  dadataPayload      Json?
  // Связи
  users              WholesaleUser[]
  invitations        WholesaleInvitation[]
  accessRequests     WholesaleAccessRequest[]
  creditTx           WholesaleCreditTransaction[]
  documents          WholesaleDocument[]
  invoices           WholesaleInvoice[]
  orders             Order[]
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  @@index([status])
  @@index([managerAdminId])
  @@index([priceListId])
}

// Приглашение сотрудника в оптовый кабинет. Owner компании генерирует
// инвайт → на email приходит ссылка с одноразовым токеном → сотрудник
// устанавливает пароль и становится WholesaleUser той же компании.
model WholesaleInvitation {
  id          String           @id @default(cuid())
  companyId   String
  company     WholesaleCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email       String
  role        String           @default("buyer") // "buyer" | "accountant"
  token       String           @unique // одноразовый, crypto.randomBytes(32)
  invitedById String? // WholesaleUser.id (owner) или AdminUser.id
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime         @default(now())

  @@index([companyId])
  @@index([email])
  @@index([expiresAt])
}

// Счёт на оплату, сгенерированный для оптового заказа (PDF + номер).
// Отделён от WholesaleDocument чтобы хранить структурированные данные
// (для повторной генерации PDF, отчётов бухгалтерии, отправки в ЭДО).
model WholesaleInvoice {
  id             String           @id @default(cuid())
  number         String           @unique // "INV-2026-0001" — сквозная годовая нумерация
  kind           String           @default("invoice") // "invoice" | "upd" | "act"
  orderId        String?          @unique // один счёт на заказ (для UPD/invoice)
  companyId      String
  company        WholesaleCompany @relation(fields: [companyId], references: [id], onDelete: Restrict)
  // Snapshot цен — чтобы при rerender PDF не зависеть от меняющегося каталога
  subtotal       Int
  discount       Int              @default(0)
  total          Int
  vatRate        Int? // % НДС (обычно 20 или 0). null = без НДС (УСН).
  vatAmount      Int?
  // Snapshot реквизитов плательщика и получателя
  buyerSnapshot  Json // { legalName, inn, kpp, address, bankName, bankAccount, bic }
  sellerSnapshot Json // { legalName, inn, kpp, address, bankName, bankAccount, bic }
  itemsSnapshot  Json // [{ name, weight, quantity, price, total }]
  // Статус жизненного цикла
  status         String           @default("draft") // "draft" | "sent" | "paid" | "cancelled"
  pdfUrl         String? // /uploads/wholesale/invoices/...pdf
  generatedById  String? // AdminUser.id
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([companyId, createdAt])
  @@index([status])
  @@index([kind, createdAt])
}

// Пользователь B2B-кабинета. С Фазы 7 — поддержка нескольких юзеров от одной
// компании с ролями. Роли: "owner" (создал компанию, может приглашать), "buyer"
// (оформляет заказы), "accountant" (видит счета и финансы, не оформляет заказы).
model WholesaleUser {
  id            String           @id @default(cuid())
  email         String           @unique
  emailVerified DateTime?
  // passwordHash nullable — сотрудник получил приглашение, но ещё не задал пароль.
  // До этого момента status="pending", войти нельзя.
  passwordHash  String?
  name          String
  phone         String?
  role          String           @default("buyer") // "owner" | "buyer" | "accountant"
  status        String           @default("active") // "pending" | "active" | "blocked"
  companyId     String
  company       WholesaleCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lastLoginAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([companyId])
}

// Заявка на оптовый доступ — создаётся на публичной странице /wholesale/register.
// После апрува админом создаются связанные WholesaleCompany + WholesaleUser.
// До этого момента заявитель не может залогиниться.
model WholesaleAccessRequest {
  id             String            @id @default(cuid())
  // Что ввёл заявитель
  legalName      String
  inn            String
  contactName    String
  contactPhone   String
  contactEmail   String
  expectedVolume String?           @db.Text // «~500кг/мес», произвольный текст
  comment        String?           @db.Text
  // Привязка после апрува (companyId становится не-null)
  companyId      String?
  company        WholesaleCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  status         String            @default("pending") // "pending" | "approved" | "rejected"
  reviewedById   String? // AdminUser.id
  reviewedAt     DateTime?
  reviewerNote   String?           @db.Text
  // Аудит для защиты от спама
  ipAddress      String?
  userAgent      String?           @db.Text
  createdAt      DateTime          @default(now())

  @@index([status, createdAt])
  @@index([inn])
  @@index([contactEmail])
}

// Прайс-лист — коллекция кастомных цен. Привязывается к нулю или
// нескольким WholesaleCompany. kind="fixed" — items задают точные цены;
// kind="discount_pct" — к розничной цене применяется discountPct, items
// (если есть) переопределяют для отдельных SKU.
model PriceList {
  id          String             @id @default(cuid())
  name        String // "Базовый опт" | "Сеть Х" | "VIP"
  description String?            @db.Text
  isActive    Boolean            @default(true)
  kind        String             @default("fixed") // "fixed" | "discount_pct"
  discountPct Int? // 20 = -20% к розничной; только для kind="discount_pct"
  minOrderSum Int? // минимальная сумма заказа для использования этого прайса
  items       PriceListItem[]
  companies   WholesaleCompany[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([isActive])
}

// Позиция прайс-листа — оверрайд цены для конкретного варианта товара.
// minQuantity=1 — применяется всегда. Для tier pricing (Фаза 5) будет
// несколько записей с разным minQuantity для одного варианта.
model PriceListItem {
  id          String         @id @default(cuid())
  priceListId String
  priceList   PriceList      @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  variantId   String
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  price       Int // финальная цена за единицу в рублях
  minQuantity Int            @default(1)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([priceListId, variantId, minQuantity])
  @@index([priceListId])
  @@index([variantId])
}

// Журнал операций по кредиту компании (финансовый ledger).
// Положительный amount увеличивает долг (новый заказ с отсрочкой),
// отрицательный — уменьшает (оплата или отмена). idempotencyKey
// защищает от дублей при retry webhook/cron.
model WholesaleCreditTransaction {
  id             String           @id @default(cuid())
  companyId      String
  company        WholesaleCompany @relation(fields: [companyId], references: [id], onDelete: Restrict)
  amount         Int // +N заказ, -N оплата/отмена
  type           String // "order_placed" | "order_cancelled" | "payment_received" | "adjustment"
  orderId        String?
  description    String?
  idempotencyKey String?          @unique
  createdBy      String? // AdminUser.id | "system"
  createdAt      DateTime         @default(now())

  @@index([companyId, createdAt])
  @@index([orderId])
}

// Документы компании — договор, карточка компании, счета/УПД/акты.
// В MVP только модель и базовый upload через админку. Полноценная
// генерация PDF — Фаза 5.
model WholesaleDocument {
  id           String           @id @default(cuid())
  companyId    String
  company      WholesaleCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  kind         String // "contract" | "company_card" | "invoice" | "upd" | "act"
  orderId      String? // для invoice/upd/act
  fileUrl      String // /uploads/wholesale/{companyId}/...
  fileName     String
  fileSize     Int
  uploadedById String? // AdminUser.id
  createdAt    DateTime         @default(now())

  @@index([companyId, kind, createdAt])
  @@index([orderId])
}
