DATABASE_URL="postgresql://roznica:PASSWORD@localhost:5432/roznica?schema=public"
NEXTAUTH_SECRET="generate-a-random-secret"
NEXTAUTH_URL="https://your-domain.com"

# OAuth (optional — buttons shown only when configured)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# Telegram Login (optional)
TELEGRAM_BOT_TOKEN=

# SMTP (Beget)
SMTP_HOST=smtp.beget.com
SMTP_PORT=465
SMTP_USER=noreply@millor-coffee.ru
SMTP_PASSWORD=

# SEO verification (optional)
GOOGLE_SITE_VERIFICATION=
YANDEX_VERIFICATION=

# Delivery webhooks / external integrations
CDEK_WEBHOOK_SECRET=
TRACKING_POLL_SECRET=

# millorbot-delivery integration
# Internal URL in the shared docker network, reachable from both site and worker.
MILLORBOT_ENABLED=false
MILLORBOT_URL=http://millor-telegram-router:8000
# 64-byte hex. Generate: openssl rand -hex 32
MILLORBOT_SHARED_SECRET=

# Outbox worker tuning
OUTBOX_POLL_INTERVAL_MS=5000
OUTBOX_MAX_ATTEMPTS=10
